#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: xcode workstreams/<workstream-id> [codex-args...]
   or: xcode <workstream-id> [codex-args...]

Start Codex in a workstream execution directory and add the shared root as an extra writable directory.
Run this from the shared project root.
EOF
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
root_dir="$(cd -- "${script_dir}/.." && pwd -P)"

target_arg="${1:-}"
if [[ -z "${target_arg}" ]]; then
  usage
  exit 2
fi
shift

target_arg="${target_arg%/}"

case "${target_arg}" in
  workstreams/*)
    target_path="${target_arg}"
    ;;
  *)
    target_path="workstreams/${target_arg}"
    ;;
esac

workstream_id="${target_path#workstreams/}"

if [[ -z "${workstream_id}" || "${workstream_id}" == "${target_path}" || "${workstream_id}" == */* ]]; then
  echo "xcode: expected a single workstream execution directory under workstreams/." >&2
  usage
  exit 2
fi

if [[ ! "${workstream_id}" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
  echo "xcode: invalid workstream id '${workstream_id}': use only lowercase letters, digits, hyphens, and underscores." >&2
  exit 2
fi

if [[ ! -d "${root_dir}/${target_path}" ]]; then
  echo "xcode: workstream execution directory not found: ${target_path}" >&2
  exit 1
fi

metadata_path="${root_dir}/.work/workstreams/${workstream_id}/workstream.toml"

if [[ ! -f "${metadata_path}" ]]; then
  echo "xcode: shared workstream metadata is missing for: ${workstream_id}" >&2
  exit 1
fi

workstream_type="$(grep -m1 -E '^\s*type\s*=' "${metadata_path}" | sed -E "s/^[[:space:]]*type[[:space:]]*=[[:space:]]*[\"']([^\"']*)[\"'].*/\1/")"

if [[ -z "${workstream_type}" ]]; then
  echo "xcode: could not determine workstream type from: ${metadata_path}" >&2
  exit 1
fi

case "${workstream_type}" in
  repo)
    if [[ ! -e "${root_dir}/${target_path}/.git" ]]; then
      echo "xcode: repo workstream does not look like a git worktree root: ${target_path}" >&2
      exit 1
    fi
    ;;
  daily)
    ;;
  *)
    echo "xcode: unsupported workstream type '${workstream_type}' in ${metadata_path}" >&2
    exit 1
    ;;
esac

if [[ ! -f "${root_dir}/${target_path}/AGENTS.md" ]]; then
  echo "xcode: workstream runtime shell is incomplete; missing AGENTS.md in ${target_path}" >&2
  exit 1
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "xcode: codex is not available on PATH." >&2
  exit 127
fi

cd -- "${root_dir}"
exec codex -C "${target_path}" --add-dir . "$@"
